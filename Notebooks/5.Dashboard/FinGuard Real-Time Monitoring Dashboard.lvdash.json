{
  "datasets": [
    {
      "name": "recent_fraud_alerts",
      "displayName": "Recent Fraud Alerts",
      "queryLines": [
        "SELECT\n",
        "  alert_timestamp,\n",
        "  customer_name,\n",
        "  customer_email,\n",
        "  transaction_amount,\n",
        "  currency,\n",
        "  merchant_name,\n",
        "  merchant_category,\n",
        "  risk_level,\n",
        "  reason_description,\n",
        "  transaction_country\n",
        "FROM\n",
        "  finguard.gold.fraud_card_alert\n",
        "ORDER BY\n",
        "  alert_timestamp DESC\n",
        "LIMIT 100"
      ],
      "catalog": "finguard",
      "schema": "gold"
    },
    {
      "name": "recent_high_value_alerts",
      "displayName": "Recent High Value Alerts",
      "queryLines": [
        "SELECT\n",
        "  alert_timestamp,\n",
        "  customer_name,\n",
        "  customer_email,\n",
        "  transaction_amount,\n",
        "  transaction_limit,\n",
        "  currency,\n",
        "  merchant_name,\n",
        "  merchant_category,\n",
        "  payment_channel,\n",
        "  country\n",
        "FROM\n",
        "  finguard.gold.high_value_transactions_alert\n",
        "ORDER BY\n",
        "  alert_timestamp DESC\n",
        "LIMIT 100"
      ],
      "catalog": "finguard",
      "schema": "gold"
    },
    {
      "name": "streaming_metrics",
      "displayName": "Streaming Transaction Rate",
      "queryLines": [
        "SELECT\n",
        "  window_start,\n",
        "  window_end,\n",
        "  transaction_count\n",
        "FROM\n",
        "  finguard.gold.transaction_count_by_minute\n",
        "ORDER BY\n",
        "  window_start DESC"
      ],
      "catalog": "finguard",
      "schema": "gold"
    },
    {
      "name": "high_value_alert_metrics",
      "displayName": "High Value Alert Metrics",
      "config": {
        "version": "1.1",
        "source": "finguard.gold.high_value_transactions_alert",
        "dimensions": [
          {
            "name": "alert_date",
            "expr": "DATE_TRUNC('day', alert_timestamp)"
          },
          {
            "name": "alert_hour",
            "expr": "DATE_TRUNC('hour', alert_timestamp)"
          },
          {
            "name": "merchant_category",
            "expr": "merchant_category"
          },
          {
            "name": "payment_channel",
            "expr": "payment_channel"
          },
          {
            "name": "country",
            "expr": "country"
          }
        ],
        "measures": [
          {
            "name": "total_high_value_alerts",
            "expr": "COUNT(*)"
          },
          {
            "name": "total_high_value_amount",
            "expr": "SUM(transaction_amount)"
          },
          {
            "name": "avg_high_value_amount",
            "expr": "AVG(transaction_amount)"
          },
          {
            "name": "affected_customers_hv",
            "expr": "COUNT(DISTINCT customer_id)"
          }
        ]
      }
    },
    {
      "name": "fraud_alert_metrics",
      "displayName": "Fraud Alert Metrics",
      "config": {
        "version": "1.1",
        "source": "finguard.gold.fraud_card_alert",
        "dimensions": [
          {
            "name": "alert_date",
            "expr": "DATE_TRUNC('day', alert_timestamp)"
          },
          {
            "name": "alert_hour",
            "expr": "DATE_TRUNC('hour', alert_timestamp)"
          },
          {
            "name": "risk_level",
            "expr": "risk_level"
          },
          {
            "name": "watch_type",
            "expr": "watch_type"
          },
          {
            "name": "reason_code",
            "expr": "reason_code"
          },
          {
            "name": "transaction_country",
            "expr": "transaction_country"
          },
          {
            "name": "merchant_category",
            "expr": "merchant_category"
          }
        ],
        "measures": [
          {
            "name": "total_fraud_alerts",
            "expr": "COUNT(*)"
          },
          {
            "name": "total_fraud_amount",
            "expr": "SUM(transaction_amount)"
          },
          {
            "name": "avg_fraud_amount",
            "expr": "AVG(transaction_amount)"
          },
          {
            "name": "affected_customers",
            "expr": "COUNT(DISTINCT customer_id)"
          }
        ]
      }
    },
    {
      "name": "transaction_metrics",
      "displayName": "Transaction Metrics",
      "config": {
        "version": "1.1",
        "source": "finguard.silver.transactions",
        "dimensions": [
          {
            "name": "transaction_date",
            "expr": "DATE_TRUNC('day', transaction_timestamp)"
          },
          {
            "name": "transaction_hour",
            "expr": "DATE_TRUNC('hour', transaction_timestamp)"
          },
          {
            "name": "merchant_category",
            "expr": "merchant_category"
          },
          {
            "name": "payment_channel",
            "expr": "payment_channel"
          },
          {
            "name": "country",
            "expr": "country"
          },
          {
            "name": "transaction_type",
            "expr": "transaction_type"
          },
          {
            "name": "status",
            "expr": "status"
          },
          {
            "name": "is_international",
            "expr": "is_international"
          }
        ],
        "measures": [
          {
            "name": "total_transactions",
            "expr": "COUNT(*)"
          },
          {
            "name": "total_amount",
            "expr": "SUM(amount)"
          },
          {
            "name": "total_amount_millions",
            "expr": "SUM(amount) / 1000000.0"
          },
          {
            "name": "avg_transaction_amount",
            "expr": "AVG(amount)"
          },
          {
            "name": "unique_customers",
            "expr": "COUNT(DISTINCT customer_id)"
          },
          {
            "name": "unique_merchants",
            "expr": "COUNT(DISTINCT merchant_id)"
          }
        ]
      }
    }
  ],
